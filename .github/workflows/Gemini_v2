name: Download, Split and Release

on:
  workflow_dispatch:
    inputs:
      url:
        description: '需要下载的 URL'
        required: true
        type: string
      split_size:
        description: '分卷大小 (单位: MB)'
        required: true
        default: '50'
        type: string

jobs:
  process-and-release:
    runs-on: ubuntu-latest
    permissions:
      contents: write

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Prepare directories
        run: |
          mkdir -p dl_folder
          mkdir -p output_folder

      - name: Download file
        run: |
          cd dl_folder
          # 使用引号包裹变量防止 YAML 解析错误
          echo "Processing URL: ${{ github.event.inputs.url }}"
          wget --content-disposition --trust-server-names "${{ github.event.inputs.url }}"

      - name: Zip and split file
        run: |
          cd dl_folder
          # 确保 split_size 也是安全的
          zip -s "${{ github.event.inputs.split_size }}m" ../output_folder/archive.zip ./*
          
      - name: Generate timestamp
        id: time
        run: echo "tag=$(date +'%Y-%m-%d-%H-%M-%S')" >> $GITHUB_OUTPUT

      - name: Create Release
        uses: softprops/action-gh-release@v2
        with:
          tag_name: task-${{ steps.time.outputs.tag }}
          name: "Auto-Release ${{ steps.time.outputs.tag }}"
          body: "Source URL: ${{ github.event.inputs.url }}"
          files: output_folder/*
