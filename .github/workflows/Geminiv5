name: Download Split and Release

on:
  workflow_dispatch:
    inputs:
      url:
        description: 'URL'
        required: true
        type: string
      split_size:
        description: 'MB'
        required: true
        default: '50'
        type: string

jobs:
  process:
    runs-on: ubuntu-latest
    permissions:
      contents: write

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup
        run: |
          mkdir -p dl_folder
          mkdir -p output_folder

      - name: Download
        env:
          DL_URL: ${{ github.event.inputs.url }}
        run: |
          cd dl_folder
          wget --content-disposition --trust-server-names "$DL_URL"

      - name: Zip
        env:
          SZ: ${{ github.event.inputs.split_size }}
        run: |
          cd dl_folder
          zip -s "${SZ}m" ../output_folder/archive.zip ./*

      - name: Time
        id: time
        run: echo "tag=$(date +'%Y%m%d%H%M%S')" >> $GITHUB_OUTPUT

      - name: Release
        uses: softprops/action-gh-release@v2
        with:
          tag_name: "rel-${{ steps.time.outputs.tag }}"
          name: "Release ${{ steps.time.outputs.tag }}"
          body: "Download from ${{ github.event.inputs.url }}"
          files: output_folder/*

