name: Download URL + Split ZIP + Upload to Release

on:
  workflow_dispatch:          # 手动触发（最方便输入 URL）
    inputs:
      download_url:
        description: '要下载的文件 URL'
        required: true
        type: string
      release_tag:
        description: 'Release 的 Tag（如 v1.0.0 或 latest）'
        required: true
        default: 'latest'
        type: string
      split_size:
        description: '每卷大小（例如 100M、500M、1G）'
        required: false
        default: '500M'
        type: string

jobs:
  process:
    runs-on: ubuntu-latest
    permissions:
      contents: write          # 必须有权限才能上传 Release assets

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Download file from URL
        run: |
          wget -q --show-progress "${{ inputs.download_url }}" -O downloaded_file
          ls -lh downloaded_file
          echo "下载完成，文件大小：$(du -sh downloaded_file | cut -f1)"

      - name: Install 7-Zip (if needed)
        run: sudo apt-get update && sudo apt-get install -y p7zip-full

      - name: Split compress into 2 volumes (7z format)
        run: |
          # 使用 7z 分卷压缩，强制分成 2 份左右
          # -v${{ inputs.split_size }} 表示每卷大小
          7z a -v${{ inputs.split_size }} -mx=5 "split_archive.7z" downloaded_file

          # 重命名为更清晰的名字（推荐 .part1.7z .part2.7z）
          mv split_archive.7z.001 split_archive.part01.7z
          mv split_archive.7z.002 split_archive.part02.7z 2>/dev/null || true

          ls -lh split_archive.*

      - name: Create or Update Release and Upload Assets
        uses: softprops/action-gh-release@v2
        with:
          tag_name: ${{ inputs.release_tag }}
          name: "Split Archive - ${{ inputs.release_tag }}"
          draft: false
          prerelease: false
          files: |
            split_archive.part01.7z
            split_archive.part02.7z
          token: ${{ secrets.GITHUB_TOKEN }}
